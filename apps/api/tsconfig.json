{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext"],
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "node"],
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"]
}